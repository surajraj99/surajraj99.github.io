---
import SocialIcons from "./SocialIcons.astro";

const year = 2026;
---

<footer class="mt-24 border-t border-line bg-white">
  <div class="container-tight py-12">
    <div class="grid gap-10 md:grid-cols-2">
      <div>
        <p class="text-lg font-semibold text-ink-900">Suraj Rajendran</p>
        <p class="mt-1 text-sm text-ink-500">
          Computational biologist. Building AI for healthcare.
        </p>
        <div class="mt-5">
          <SocialIcons variant="light" />
        </div>
      </div>

      <div class="md:text-right">
        <nav class="flex flex-wrap gap-5 md:justify-end" aria-label="Footer">
          <a href="/" class="text-sm text-ink-700 hover:text-brand-500 transition-colors">About</a>
          <a href="/publications/" class="text-sm text-ink-700 hover:text-brand-500 transition-colors">Publications</a>
          <a href="/news/" class="text-sm text-ink-700 hover:text-brand-500 transition-colors">News</a>
          <a href="/talks/" class="text-sm text-ink-700 hover:text-brand-500 transition-colors">Talks</a>
          <a href="/cv/" class="text-sm text-ink-700 hover:text-brand-500 transition-colors">CV</a>
        </nav>
        <p class="mt-6 text-xs text-ink-500">
          © {year} Suraj Rajendran · Built with Astro & Tailwind
        </p>
      </div>
    </div>
  </div>
</footer>
