---
const stats = [
  { value: "10+", label: "Publications" },
  { value: "NSF GRFP", label: "Fellow" },
  { value: "Nature · Lancet · npj", label: "Venues" },
  { value: "18M+", label: "IVF Images Trained On" },
];
---

<section class="bg-bg-white border-b border-line">
  <div class="container-tight py-12 md:py-16">
    <div class="grid gap-6 grid-cols-2 md:grid-cols-4">
      {stats.map((s) => (
        <div class="fade-in text-center md:text-left">
          <p class="text-2xl md:text-3xl font-bold tracking-tightish text-ink-900">
            {s.value}
          </p>
          <p class="mt-1.5 text-sm font-medium uppercase tracking-wider text-ink-500">
            {s.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
