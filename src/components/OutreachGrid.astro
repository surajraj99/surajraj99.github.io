---
const items = [
  {
    title: "IMentor",
    tagline: "Mentor · Since 2023",
    body:
      "Mentoring underprivileged high school students in NYC through the college application process.",
    href: "https://www.imentor.org/",
  },
  {
    title: "Lumiere Education",
    tagline: "Research Mentor",
    body:
      "Guiding students exploring machine learning applications in healthcare.",
    href: "https://www.lumiere-education.com/",
  },
  {
    title: "Equity & Access — Georgia Tech EPICS",
    tagline: "Policy Lead",
    body:
      "Led a team that proposed policy changes for academic recognition of students with disabilities.",
    href: "https://www.me.gatech.edu/news/team-epics-wins-student-innovation-competition-promoting-equity-access",
  },
  {
    title: "HHS “Giving=Living”",
    tagline: "Winning Proposal",
    body:
      "Led the winning proposal for the HHS public-health campaign to promote blood donations.",
    href: null,
  },
];
---

<section class="bg-bg-soft">
  <div class="container-tight py-16 md:py-20">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-500">
        Outreach & Service
      </p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 tracking-tightish">
        Mentorship & equity in academia.
      </h2>
      <p class="mt-3 text-base text-ink-500">
        Work I'm proud of, beyond research.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {items.map((it) => (
        <article class="card-lift fade-in rounded-xl border border-line bg-white p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-cyan-500">
            {it.tagline}
          </p>
          <h3 class="mt-2 text-lg font-semibold text-ink-900">
            {it.href ? (
              <a
                href={it.href}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-brand-500 transition-colors"
              >
                {it.title}
              </a>
            ) : (
              it.title
            )}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-700">{it.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
