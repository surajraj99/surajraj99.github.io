---
interface Props {
  pathname: string;
}
const { pathname } = Astro.props;

const links = [
  { href: "/", label: "About" },
  { href: "/publications/", label: "Publications" },
  { href: "/news/", label: "News" },
  { href: "/talks/", label: "Talks" },
  { href: "/cv/", label: "CV" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/" || pathname === "";
  return pathname.startsWith(href);
}
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <div class="container-tight flex h-16 items-center justify-between">
    <a
      href="/"
      class="font-bold text-lg tracking-tightish text-ink-900 hover:text-brand-500 transition-colors"
    >
      Suraj Rajendran
    </a>

    <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class={`relative text-sm font-medium transition-colors ${
            isActive(l.href)
              ? "text-brand-600"
              : "text-ink-700 hover:text-brand-500"
          }`}
        >
          {l.label}
          {isActive(l.href) && (
            <span
              class="absolute -bottom-1.5 left-0 right-0 h-0.5 rounded-full bg-brand-500"
            />
          )}
        </a>
      ))}
    </nav>

    <button
      id="mobile-menu-toggle"
      class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-md text-ink-700 hover:bg-line/60 transition-colors"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-line bg-white/95 backdrop-blur-md"
  >
    <nav class="container-tight flex flex-col py-3" aria-label="Mobile">
      {links.map((l) => (
        <a
          href={l.href}
          class={`py-3 text-base font-medium transition-colors ${
            isActive(l.href)
              ? "text-brand-600"
              : "text-ink-700 hover:text-brand-500"
          }`}
        >
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<div class="h-16" aria-hidden="true"></div>

<script>
  const nav = document.getElementById("site-nav");
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 8) {
      nav.dataset.scrolled = "true";
      nav.classList.add(
        "bg-white/80",
        "backdrop-blur-md",
        "border-b",
        "border-line",
      );
    } else {
      nav.dataset.scrolled = "false";
      nav.classList.remove(
        "bg-white/80",
        "backdrop-blur-md",
        "border-b",
        "border-line",
      );
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    if (!menu) return;
    const open = menu.classList.contains("hidden");
    menu.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
  });
</script>
