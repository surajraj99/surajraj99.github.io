---
import SocialIcons from "./SocialIcons.astro";
---

<section class="relative overflow-hidden bg-ink-900 text-white">
  <!-- Subtle background grid + gradient glow -->
  <div
    class="absolute inset-0 opacity-30 pointer-events-none"
    style="background-image: radial-gradient(circle at 80% 20%, rgba(99,102,241,0.45), transparent 50%), radial-gradient(circle at 10% 90%, rgba(6,182,212,0.25), transparent 45%);"
  ></div>
  <div
    class="absolute inset-0 opacity-[0.07] pointer-events-none"
    style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 64px 64px;"
  ></div>

  <div class="container-tight relative py-20 md:py-28">
    <div class="grid items-center gap-12 md:grid-cols-[1.4fr_1fr]">
      <div class="order-2 md:order-1">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-cyan-500">
          Research Scientist
        </p>
        <h1 class="mt-4 text-5xl md:text-6xl lg:text-7xl font-bold tracking-tightish leading-[1.05]">
          Suraj Rajendran
        </h1>
        <p class="mt-5 text-lg md:text-xl text-slate-300 max-w-xl leading-relaxed">
          Computational biologist building AI for healthcare. I recently
          completed my Ph.D. at Weill Cornell Medicine, where I developed
          multimodal models for IVF and women's health, federated learning
          for clinical trial emulation, and NLP systems for medical data.
        </p>
        <p class="mt-4 text-base md:text-lg text-slate-400 max-w-xl">
          Now transitioning into industry research, pushing on foundation
          models for medicine.
        </p>

        <div class="mt-8">
          <SocialIcons variant="dark" size={22} />
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href="/publications/"
            class="inline-flex items-center gap-2 rounded-md bg-brand-500 hover:bg-brand-600 px-5 py-2.5 text-sm font-medium text-white shadow-lg shadow-brand-500/20 transition-colors"
          >
            See publications
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a
            href="/cv/"
            class="inline-flex items-center gap-2 rounded-md border border-white/20 hover:border-white/40 hover:bg-white/5 px-5 py-2.5 text-sm font-medium text-white transition-colors"
          >
            Download CV
          </a>
        </div>
      </div>

      <div class="order-1 md:order-2 flex justify-center md:justify-end">
        <div class="relative">
          <div
            class="absolute -inset-4 rounded-full bg-brand-500/30 blur-2xl"
            aria-hidden="true"
          ></div>
          <div
            class="absolute -inset-1 rounded-full bg-gradient-to-br from-brand-500 via-brand-500/40 to-cyan-500"
            aria-hidden="true"
          ></div>
          <img
            src="/assets/img/prof_pic.jpg"
            alt="Suraj Rajendran"
            class="relative w-56 h-56 md:w-72 md:h-72 rounded-full object-cover ring-4 ring-ink-900 shadow-2xl"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>
