---
interface Props {
  title: string;
  date: Date;
  event?: string;
  location?: string;
  type?: string;
  slides?: string;
  video?: string;
}

const { title, date, event, location, type, slides, video } = Astro.props;

const dateLabel = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(date);
---

<article class="card-lift fade-in flex h-full flex-col rounded-xl border border-line bg-white p-6 shadow-sm">
  <div class="flex flex-wrap items-center gap-2">
    {type && (
      <span class="inline-flex items-center rounded-full bg-brand-500/10 px-2.5 py-1 text-xs font-semibold text-brand-600">
        {type}
      </span>
    )}
    <span class="text-xs font-medium uppercase tracking-wider text-ink-500">
      {dateLabel}
    </span>
  </div>

  <h3 class="mt-3 text-base md:text-lg font-semibold text-ink-900 leading-snug">
    {title}
  </h3>

  {event && (
    <p class="mt-2 text-sm font-medium text-ink-700">{event}</p>
  )}
  {location && (
    <p class="text-sm italic text-ink-500">{location}</p>
  )}

  <div class="mt-4 prose-talk text-sm text-ink-700">
    <slot />
  </div>

  {(slides || video) && (
    <div class="mt-4 flex flex-wrap gap-2">
      {slides && (
        <a
          href={slides}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-xs font-semibold text-ink-700 hover:border-brand-500 hover:text-brand-500 transition-colors"
        >
          Slides
        </a>
      )}
      {video && (
        <a
          href={video}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-xs font-semibold text-ink-700 hover:border-brand-500 hover:text-brand-500 transition-colors"
        >
          Video
        </a>
      )}
    </div>
  )}
</article>

<style>
  .prose-talk :global(p) {
    margin: 0;
    line-height: 1.6;
  }
  .prose-talk :global(a) {
    color: theme("colors.brand.500");
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .prose-talk :global(a:hover) {
    color: theme("colors.brand.600");
  }
</style>
