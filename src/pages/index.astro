---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import InterestChips from "../components/InterestChips.astro";
import PublicationCard from "../components/PublicationCard.astro";
import NewsTimelineItem from "../components/NewsTimelineItem.astro";
import OutreachGrid from "../components/OutreachGrid.astro";
import ContactCallout from "../components/ContactCallout.astro";
import { getCollection, render } from "astro:content";

const allPubs = await getCollection("publications");
const sortedByYear = [...allPubs].sort((a, b) => b.data.year - a.data.year);
const starred = sortedByYear.filter((p) => p.data.featured);
const padding = sortedByYear.filter((p) => !p.data.featured).slice(0, 3 - starred.length);
const featured = [...starred, ...padding].slice(0, 3);

const allNews = (await getCollection("news")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const recentNews = allNews.slice(0, 4);

// Pre-render the recent news markdown so we can <Content /> them
const recentRendered = await Promise.all(
  recentNews.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<Base
  title="Suraj Rajendran — Computational Biology & Healthcare AI"
  description="Personal research site for Suraj Rajendran — Ph.D., Weill Cornell Medicine. Multimodal AI for IVF, federated learning, clinical trial emulation."
>
  <Hero />
  <InterestChips />

  <!-- Featured publications -->
  <section class="bg-bg-white border-y border-line">
    <div class="container-tight py-16 md:py-20">
      <div class="flex items-end justify-between gap-6">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-500">
            Featured Publications
          </p>
          <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 tracking-tightish">
            Selected work.
          </h2>
        </div>
        <a
          href="/publications/"
          class="hidden md:inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-500"
        >
          See all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {featured.map((p) => (
          <div class="fade-in">
            <PublicationCard
              title={p.data.title}
              authors={p.data.authors}
              venue={p.data.venue}
              year={p.data.year}
              doi={p.data.doi}
              pdf={p.data.pdf}
              html={p.data.html}
              featured={p.data.featured}
            />
          </div>
        ))}
      </div>

      <div class="mt-8 md:hidden">
        <a
          href="/publications/"
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-500"
        >
          See all publications
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent news -->
  <section class="bg-bg-soft">
    <div class="container-tight py-16 md:py-20">
      <div class="flex items-end justify-between gap-6">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-500">
            Recent News
          </p>
          <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 tracking-tightish">
            What's new.
          </h2>
        </div>
        <a
          href="/news/"
          class="hidden md:inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-500"
        >
          See all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <ul class="mt-10 relative border-l-2 border-brand-500/20 space-y-6">
        {recentRendered.map(({ entry, Content }) => (
          <NewsTimelineItem date={entry.data.date} icon={entry.data.icon}>
            <Content />
          </NewsTimelineItem>
        ))}
      </ul>

      <div class="mt-8 md:hidden">
        <a
          href="/news/"
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-500"
        >
          See all news
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <OutreachGrid />
  <ContactCallout />
</Base>
