---
import Base from "../layouts/Base.astro";
import NewsTimelineItem from "../components/NewsTimelineItem.astro";
import { getCollection, render } from "astro:content";

const news = (await getCollection("news")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const rendered = await Promise.all(
  news.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<Base
  title="News — Suraj Rajendran"
  description="Announcements, milestones, and recent activity."
>
  <section class="bg-ink-900 text-white">
    <div class="container-tight py-16 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-cyan-500">
        News
      </p>
      <h1 class="mt-3 text-4xl md:text-5xl font-bold tracking-tightish">
        Announcements & milestones.
      </h1>
    </div>
  </section>

  <section class="bg-bg-soft">
    <div class="container-tight py-12">
      <ul class="relative border-l-2 border-brand-500/20 space-y-6">
        {rendered.map(({ entry, Content }) => (
          <NewsTimelineItem date={entry.data.date} icon={entry.data.icon}>
            <Content />
          </NewsTimelineItem>
        ))}
      </ul>
    </div>
  </section>
</Base>
