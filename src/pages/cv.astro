---
import Base from "../layouts/Base.astro";

const cvPath = "/assets/Suraj_Rajendran_CV.pdf";
---

<Base
  title="CV — Suraj Rajendran"
  description="Curriculum Vitae of Suraj Rajendran, Ph.D."
>
  <section class="bg-ink-900 text-white">
    <div class="container-tight py-16 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-cyan-500">
        Curriculum Vitae
      </p>
      <div class="mt-3 flex flex-wrap items-end justify-between gap-6">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tightish">
          Background, in one document.
        </h1>
        <a
          href={cvPath}
          download
          class="inline-flex items-center gap-2 rounded-md bg-brand-500 hover:bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-brand-500/20 transition-colors"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download PDF
        </a>
      </div>
    </div>
  </section>

  <section class="bg-bg-soft">
    <div class="container-tight py-12">
      <div class="rounded-xl border border-line bg-white p-2 shadow-sm">
        <iframe
          src={cvPath}
          class="w-full rounded-lg"
          style="height: 85vh;"
          title="Suraj Rajendran — Curriculum Vitae"
        ></iframe>
      </div>

      <p class="mt-4 text-center text-sm text-ink-500">
        Trouble viewing the PDF?
        <a
          href={cvPath}
          class="font-semibold text-brand-600 hover:text-brand-500"
        >
          Open it in a new tab.
        </a>
      </p>
    </div>
  </section>
</Base>
